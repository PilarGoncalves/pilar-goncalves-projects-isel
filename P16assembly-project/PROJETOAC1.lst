 292           	; Rotina: state_config
 293           	; Descricao: Acende o LED L3 a amarelo, o LED L2 a verde intermitente e o LED L1 a amarelo intermitente. 
 294           	;            Define o valor do periodo de tempo CROSSING_TIME alterando a combinacao nos bits da entrada TIME
 295           	state_config: 
 296           	; r6 = sm_state
 297           	
 298 013C 00 63	    mov r0, #MODE_MASK                   ; Seleciona os bits do outport correspondentes ao modo que vao ser alterados
 299 013E 01 63	    mov r1, #MODE_A                      ; Seleciona os bits da cor pretendida (amarelo)
 300 0140 61 5C	    bl outport_set_bits                  ; Coloca os bits correspondente Ă  cor a 1, ou seja, LED L3 liga a amarelo
 301           	
 302 0142 00 60	    mov r0, #FLASHING_ON_ENTRY           
 303 0144 60 B8	    cmp r6, r0
 304 0146 06 40	    beq state_flashing_on_entry_config   ; Se for igual vai para o estado onde o LED Ă© acesso
 305 0148 10 60	    mov r0, #FLASHING_ON_DO
 306 014A 60 B8	    cmp r6, r0 
 307 014C 0D 40	    beq state_flashing_on_do_config      ; Se for igual vai para o estado onde Ă© verificado se jĂˇ se passaram 0,5s em que o LED estava aceso
 308 014E 20 60	    mov r0, #FLASHING_OFF_DO
 309 0150 60 B8	    cmp r6, r0
 310 0152 1B 40	    beq state_flashing_off_do_config     ; Se for igual vai para o estado onde Ă© verificado se jĂˇ se passaram 0,5s em que o LED estava apagado
 311           	 
 312           	state_flashing_on_entry_config:
 313 0154 30 60	    mov r0, #TRAFFIC_LIGHT_MASK          ; Seleciona os bits do outport correspondentes ao led do transito de veiculos que vao ser alterados
 314 0156 31 60	    mov r1, #TRAFFIC_LIGHT_A             ; Seleciona apenas os bits da cor pretendida (amarelo)
 315 0158 4B 5C	    bl outport_write_bits                ; Coloca apenas os bits correspondente Ă  cor a 1, ou seja, LED L1 liga a amarelo
 316 015A C0 60	    mov r0, #PEDESTRIAN_LIGHT_MASK       ; Selelciona os bits do outport correspondentes ao led dos peoes que vao ser alterados
 317 015C 81 60	    mov r1, #PEDESTRIAN_LIGHT_G          ; Seleciona apenas o bit da cor pretendida (verde)
 318 015E 48 5C	    bl outport_write_bits                ; Coloca apenas o bit correspondente Ă  cor a 1 e o outro a 0, ou seja, LED L2 liga a verde
 319 0160 3F 5C	    bl sysclk_get_ticks
 320 0162 04 B0	    mov r4, r0                           ; Carrega o registo r4 com o tempo de referencia
 321 0164 16 60	    mov r6, #1                           ; Carrega o registo r6 a 1 para passar para a proxima rotina
 322 0166 19 58	    b end_state_config
 323           	state_flashing_on_do_config:             
 324 0168 3B 5C	    bl sysclk_get_ticks
 325 016A 00 8A	    sub r0, r0, r4                       ; Guarda no registo r0 a subtraĂ§ĂŁo entre o tempo atual e o tempo de referencia
 326 016C 51 60	    mov r1, #BLINK_TIME
 327 016E 80 B8	    cmp r0, r1                           ; Compara o tempo de piscar com o resultado da subtraĂ§ĂŁo
 328 0170 02 48	    bhs state_flashing_off_config        ; Se esse resultado for superior a 0,5s entao vai para o estado em que o LED apaga
 329 0172 16 60	    mov r6, #1                           ; Caso esse resultado ainda foi menor que os 0,5s entao carrega o registo r6 a 1 para voltar ao estado onde se calcula o tempo decorrido
 330 0174 12 58	    b end_state_config
 331           	state_flashing_off_config:
 332 0176 30 60	    mov r0, #TRAFFIC_LIGHT_MASK          ; Seleciona os bits do outport correspondentes ao transito de veiculos que vao ser alterados
 333 0178 01 60	    mov r1, #0x00                        
 334 017A 3A 5C	    bl outport_write_bits                ; Apaga todos o LED dos bits selecionados
 335 017C C0 60	    mov r0, #PEDESTRIAN_LIGHT_MASK       ; Seleciona os bits do outport correspondentes ao transito de veiculos que vao ser alterados
 336 017E 01 60	    mov r1, #0x00                  
 337 0180 37 5C	    bl outport_write_bits                ; Apaga todos o LED dos bits selecionados
 338 0182 2E 5C	    bl sysclk_get_ticks
 339 0184 04 B0	    mov r4, r0                           ; Carrega o registo r4 com o tempo de referencia
 340 0186 26 60	    mov r6, #2                           ; Carrega o registo r6 a 2 para passar para o estado onde se calcula o tempo decorrido
 341 0188 08 58	    b end_state_config
 342           	state_flashing_off_do_config:
 343 018A 2A 5C	    bl sysclk_get_ticks                  
 344 018C 00 8A	    sub r0, r0, r4                       ; Guarda no registo r0 a subtraĂ§ĂŁo entre o tempo atual e o tempo de referencia
 345 018E 51 60	    mov r1, #BLINK_TIME
 346 0190 80 B8	    cmp r0, r1                           ; Compara o tempo de piscar com o resultado da subtraĂ§ĂŁo
 347 0192 E0 4B	    bhs state_flashing_on_entry_config   ; Se esse resultado for superior a 0,5s entao vai para o estado em que o LED acende novamente
 348 0194 26 60	    mov r6, #2                           ; Caso esse resultado ainda foi menor que os 0,5s entao carrega o registo r6 a 1 para voltar ao estado onde se calcula o tempo decorrido
 349 0196 02 5C	    bl crossing_time                     ; Chama a funcao crossing_time para alterar os valores definidos nos bits correspondentes ao TIME
 350 0198 00 58	    b end_state_config
