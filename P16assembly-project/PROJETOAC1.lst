 181 0096 01 62	    mov r1, #MODE_G                       ; Seleciona apenas o bit da cor pretendida (verde)
 182 0098 AB 5C	    bl outport_write_bits                 ; Coloca apenas o bit correspondente Ă  cor a 1 e o outro a 0, ou seja, LED L3 liga a verde
 183 009A C0 60	    mov r0, #PEDESTRIAN_LIGHT_MASK        ; Seleciona os bits do outport correspondestes ao led dos peĂµs que vao ser alterados
