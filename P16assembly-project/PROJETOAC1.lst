 139           	; DescriĂ§ĂŁo: Verifica se houve uma transicao ascendente do botao e caso isto se verifique muda para o estado de passagem de peoes
 140           	check_pedestrian_button:
 141 005E 0E 24	    push lr                               
 142 0060 04 24	    push r4                               ; Guarda os valores na pilha
 143 0062 11 60	    mov r1, #PEDESTRIAN_BUTTON            ; Carrega no registo r1 a mascara correspondente ao botao dos peoes
 144 0064 62 0D	    ldr r2, previous_button_addr
 145 0066 23 08	    ldrb r3, [r2, #0]                     ; Copia um byte da memĂłria para o registo r3
 146 0068 B3 C0	    and r3, r3, r1                        ; Guarda o estado anterior do botao no registo r3
 147 006A BE 5C	    bl inport_read                        
