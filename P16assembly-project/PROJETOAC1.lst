 191 00A8 60 B8	    cmp r6, r0 
 192 00AA 0A 40	    beq state_flashing_on_do              ; Se for igual vai para o estado onde Ă© verificado se jĂˇ se passaram 0,5s em que o LED estava aceso
 193 00AC 20 60	    mov r0, #FLASHING_OFF_DO
 194 00AE 60 B8	    cmp r6, r0
