 203 00BE 15 58	    b end_state
 204           	state_flashing_on_do:
 205 00C0 8F 5C	    bl sysclk_get_ticks 
 206 00C2 00 8A	    sub r0, r0, r4                        ; Guarda no registo r0 a subtraĂ§ĂŁo entre o tempo atual e o tempo de referencia
 207 00C4 51 60	    mov r1, #BLINK_TIME
 208 00C6 80 B8	    cmp r0, r1                            ; Compara o tempo de piscar com o resultado da subtraĂ§ĂŁo
