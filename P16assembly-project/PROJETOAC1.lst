 210 00CA 16 60	    mov r6, #1                            ; Caso esse resultado ainda foi menor que os 0,5s entao carrega o registo r6 a 1 para voltar ao estado onde se calcula o tempo decorrido
 211 00CC 0E 58	    b end_state
 212           	state_flashing_off:
 213 00CE 30 60	    mov r0, #TRAFFIC_LIGHT_MASK          ; Seleciona os bits do outport correspondentes ao transito de veiculos que vao ser alterados
