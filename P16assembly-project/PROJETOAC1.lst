 360 01A2 80 C0	    and r0, r0, r1                      ; Copia para o registo r0 o valor dos bits do TIME
 361 01A4 80 EA	    lsr r0, r0, #5                      ; Desloca os 3 bits do TIME 5 bits para a direita 
 362 01A6 00 80	    add r0, r0, r0                      ; Adiciona o valor de r0 a ele mesmo, multiplicando por 2 para deslocar para a esquerda
 363 01A8 21 0C	    ldr r1, array_addr                  ; Guarda o endereco de memoria do array no registo r1 
 364 01AA 18 10	    ldr r8, [r1 ,r0]                    ; Guarda o valor do array no endereco calculado (r1 + r0) no registo r8 
 365 01AC 0F 04	    pop pc 
