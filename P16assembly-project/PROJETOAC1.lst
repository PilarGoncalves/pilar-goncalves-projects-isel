 250           	; Rotina: state_cross
 251           	; DescriĂ§ĂŁo: Acende o LED L3 a verde, o LED L2 a verde e o LED L1 a vermelho 
 252           	;            O sistema mantem-se neste estado, no minimo, durante um periodo de tempo CROSSING_TIME 
 253           	;            Este tempo Ă© estendido por iguais periodos sempre que for detetada uma nova transicao ascendente no sinal PEDESTRIAN_BUTTON 
 254           	state_cross:
 255           	; r6 = sm_state 
 256 0108 F0 63	    mov r0, #CLEAR_ALL_BITS              ; Seleciona todos os bits do outport que vao ser alterados
 257 010A 83 5C	    bl outport_clear_bits                ; Coloca os bits selecionados a 0, ou seja, apaga todos os leds
 258 010C 00 63	    mov r0, #MODE_MASK                   ; Seleciona os bits do outport correspondentes ao modo que vao ser alterados
 259 010E 01 62	    mov r1, #MODE_G                      ; Seleciona apenas o bit da cor pretendida (verde)
 260 0110 6F 5C	    bl outport_write_bits                ; Coloca apenas o bit correspondente Ă  cor a 1 e o outro a 0, ou seja, LED L3 liga a verde
 261 0112 C0 60	    mov r0, #PEDESTRIAN_LIGHT_MASK       ; Seleciona os bits do outport correspondestes ao led dos peĂµs que vao ser alterados
 262 0114 81 60	    mov r1, #PEDESTRIAN_LIGHT_G          ; Seleciona apenas o bit da cor pretendida (verde)
 263 0116 6C 5C	    bl outport_write_bits                ; Coloca apenas o bit correspondente Ă  cor a 1 e o outro a 0, ou seja, LED L2 liga a verde
 264 0118 30 60	    mov r0, #TRAFFIC_LIGHT_MASK          ; Seleciona os bits do outport correspondestes ao led do transito dos veiculos que vao ser alterados
 265 011A 11 60	    mov r1, #TRAFFIC_LIGHT_R             ; Seleciona apenas o bit da cor pretendida (vermelho)
 266 011C 69 5C	    bl outport_write_bits                ; Coloca apenas o bit correspondente Ă  cor a 1 e o outro a 0, ou seja, LED L1 liga a vermelho
 267 011E 36 60	    mov r6, #STATE_CROSS_E               ; Carrega o registo r6 com o valor da constante STATE_CROSS_E (3)
 268 0120 05 60	    mov r5, #0                           ; Carrega o registo r5 com 0 para voltar ao estado inicial
 269           	
 270           	state_cross_entry:
 271 0122 5E 5C	    bl sysclk_get_ticks
 272 0124 04 B0	    mov r4, r0                           ; Carrega o registo r4 com o tempo de referencia
 273 0126 46 60	    mov r6, #4                           ; Carrega o registo r6 a 4 para passar para a proxima rotina    
 274 0128 08 58	    b state_cross_end
 275           	
 276           	state_delay:
 277 012A 5A 5C	    bl sysclk_get_ticks
 278 012C 00 8A	    sub r0, r0, r4                       ; Calcula o tempo decorrido, fazendo a subtracao entre o tempo atual e o tempo referencia
 279 012E 00 BC	    cmp r0, r8                           ; Compara o tempo decorrido com o tempo definido para a passagem dos peoes
 280 0130 02 48	    bhs state_cross_end_time             ; Caso o tempo decorrido for maior ou igual ao tempo definido entao vai para o main_loop 
 281 0132 46 60	    mov r6, #4                           
 282 0134 02 58	    b state_cross_end                    ; Caso o tempo percorrido seja inferior ao tempo definido entao volta a mesma rotina 
 283           	
 284           	state_cross_end_time:
