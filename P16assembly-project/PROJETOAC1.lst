 185 009E A8 5C	    bl outport_write_bits                 ; Coloca apenas o bit correspondente Ă  cor a 1 e o outro a 0, ou seja, LED L2 liga a vermelho  
 186           	
 187 00A0 00 60	    mov r0, #FLASHING_ON_ENTRY            
 188 00A2 60 B8	    cmp r6, r0                            
 189 00A4 06 40	    beq state_flashing_on_entry           ; Se for igual vai para o estado onde o LED Ă© acesso 
