 175           	; DescriĂ§ĂŁo: Acende o LED L3 a verde, o LED L2 a vermelho e o LED L1 a amarelo intermitente 
 176           	state_initial: 
 177           	; r6 = sm_state
 178           	    ;mov r0, #CLEAR_ALL_BITS              ; Seleciona todos os bits do outport que vao ser alterados
 179           	    ;bl outport_clear_bits                ; Coloca os bits selecionados a 0, ou seja, apaga todos os leds
