 150 0070 01 60	    mov r1, #0
 151 0072 B0 B8	    cmp r3, r1                            ; Compara o estado anterior do botĂŁo com 0
 152 0074 01 40	    beq button_pressed                    ; Se o botao estiver a 0, significa que estava a ser precionado, logo precisamos de ver o seu estado atual (se foi solto ou nao)
 153 0076 08 58	    b end                                 ; Se o botao nao estava a ser precionado, nao vai ser preciso ver se foi solto ou nao
 154           	button_pressed:
 155 0078 11 60	    mov r1, #1
 156 007A 10 BA	    cmp r1, r4                            ; Compara o estado atual do botĂŁo com 1
 157 007C 05 44	    bne end                               ; Caso o botao continue a 0, significa que nao foi solto
 158 007E 92 0C	    ldr r2, previous_button_addr          ; Caso tenho passado para 1, significa que houve uma transicao ascendente, logo o botao foi solto
