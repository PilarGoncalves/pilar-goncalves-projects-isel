 196           	state_flashing_on_entry:
 197 00B2 30 60	    mov r0, #TRAFFIC_LIGHT_MASK           ; Seleciona os bits do outport correspondentes ao led do transito de veiculos que vao ser alterados
 198 00B4 31 60	    mov r1, #TRAFFIC_LIGHT_A              ; Seleciona apenas os bits da cor pretendida (amarelo)
 199 00B6 9C 5C	    bl outport_write_bits                 ; Coloca apenas os bits correspondente Ă  cor a 1, ou seja, LED L1 liga a amarelo
 200 00B8 93 5C	    bl sysclk_get_ticks
 201 00BA 04 B0	    mov r4, r0                            ; Carrega o registo r4 com o tempo de referencia
